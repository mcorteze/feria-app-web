rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isCollaborator(listData) {
      return isSignedIn() &&
        listData.collaboratorUids.hasAny([request.auth.uid]);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /lists/{listId} {
      allow create: if isSignedIn() &&
        request.resource.data.collaboratorUids.hasAny([request.auth.uid]);
      allow read, update, delete: if isSignedIn() && isCollaborator(resource.data);

      match /items/{itemId} {
        function parentList() {
          return get(/databases/$(database)/documents/lists/$(listId)).data;
        }

        allow read, write: if isSignedIn() && isCollaborator(parentList());
      }
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /stalls/{stallId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
